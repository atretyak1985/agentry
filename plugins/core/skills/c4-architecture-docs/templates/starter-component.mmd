%% C4 Level 3 — Component  |  inside container {{container-name}}
%% Scope: groupings of related functionality inside ONE container. Components are NOT separately
%% deployable — they share the container's process space. Draw this level only if it adds value.
%% Every component needs a technology. Fill every {{placeholder}}.
%% Render with your project's Mermaid viewer (or the mmdc CLI). Mermaid 11.x C4 dialect: hex colors only, no sprites/!include.
C4Component
    title Component diagram for {{container-name}}

    Container_Boundary(b1, "{{container-name}}") {
        Component(api, "{{component-a}}", "{{tech}}", "{{responsibility}}")
        Component(svc, "{{component-b}}", "{{tech}}", "{{responsibility}}")
    }

    ContainerDb_Ext(db, "{{datastore}}", "{{tech}}", "{{what it stores}}")

    Rel(api, svc, "{{calls}}", "{{in-process}}")
    Rel(svc, db, "{{reads / writes}}", "{{protocol}}")

    UpdateLayoutConfig($c4ShapeInRow="2", $c4BoundaryInRow="1")
