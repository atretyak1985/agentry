%% here — focus on people and systems, not protocols. Fill every {{placeholder}}.
%% Render with your project's Mermaid viewer (or the mmdc CLI). Mermaid 11.x C4 dialect: hex colors only, no sprites/!include.
C4Context
    title System Context diagram for {{system-name}}

    Person(user, "{{user-role}}", "{{what they do}}")

    System_Boundary(b1, "{{system-name}}") {
        System(sys, "{{system-name}}", "{{one-line responsibility}}")
    }

    System_Ext(ext, "{{external-system}}", "{{why it is on this diagram}}")

    Rel(user, sys, "{{uses / does what}}", "HTTPS")
    Rel(sys, ext, "{{interaction}}", "{{protocol}}")

    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")
